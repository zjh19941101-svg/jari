}

function exportMeetingCSV(code,mid){ const s=allCourses[code]; const m=s.meetings[mid]; const ci=m.checkins||{}; const roster=s.roster||{}; const seats=s.seats||{};
  const seatById={}; for(const k of Object.keys(seats)){const[r,c]=k.split("-").map(Number); seatById[seats[k].id]=`${r+1}-${colL(seatColIdx(s,k))}`;}
  const rosterIds=Object.keys(roster); const allIds=[...new Set([...rosterIds,...Object.keys(ci)])].sort();
  const st=(id,ph)=>{ const x=ci[id]?.[ph]; if(!x)return rosterIds.length?"결석":"-"; return x.status==="late"?"지각":"출석"; };
  const rows=[["학번","이름","수업전","수업후","종합","좌석"]];
  allIds.forEach(id=>{ const both=ci[id]?.pre&&ci[id]?.post,none=!ci[id]?.pre&&!ci[id]?.post; const overall=both?"출석":none?(rosterIds.length?"결석":"-"):"불완전";
    rows.push([id,ci[id]?.name||roster[id]||"",st(id,"pre"),st(id,"post"),overall,seatById[id]||"-"]); });
  dl(rows,`${s.name||"강의"}_${m.title||mid}.csv`); }
function exportCourseCSV(code){ const s=allCourses[code]; const meetings=s.meetings||{}; const roster=s.roster||{};
  const mk=Object.keys(meetings).sort((a,b)=>(meetings[a].at||0)-(meetings[b].at||0));
  const students={}; Object.keys(roster).forEach(id=>students[id]=roster[id]);
  mk.forEach(id=>{ const ci=meetings[id].checkins||{}; Object.keys(ci).forEach(sid=>{ if(ci[sid].name)students[sid]=ci[sid].name; else if(!students[sid])students[sid]=""; }); });
  const ids=Object.keys(students).sort();
  const head=["학번","이름",...mk.map(id=>meetings[id].title||new Date(meetings[id].at).toLocaleDateString("ko-KR")),"출석률"];
  const rows=[head];
  ids.forEach(id=>{ let full=0; const cells=mk.map(mid=>{ const ci=meetings[mid].checkins?.[id]; const st=ci?((ci.pre&&ci.post)?"완전":(ci.pre||ci.post)?"반":"미"):"미"; if(st==="완전")full++; return st; });
    rows.push([id,students[id]||"",...cells, mk.length?Math.round(full/mk.length*100)+"%":"0%"]); });
  dl(rows,`${s.name||"강의"}_전체출석.csv`); }
function dl(rows,fn){ const csv="\ufeff"+rows.map(r=>r.map(x=>`"${String(x).replace(/"/g,'""')}"`).join(",")).join("\n");
  const a=document.createElement("a"); a.href=URL.createObjectURL(new Blob([csv],{type:"text/csv;charset=utf-8"})); a.download=fn; a.click(); toast("내보내기 완료","ok"); }

