  }));
  allCoursesCache=all;
  const courseRows=[]; let totMeet=0,totFull=0;
  for(const code of Object.keys(all)){ const c=all[code]; const meetings=c.meetings||{};
    const mk=Object.keys(meetings); let attended=0,full=0,late=0;
    mk.forEach(id=>{ const ci=meetings[id].checkins?.[ME.id]; if(ci){ if(ci.pre||ci.post)attended++; if(ci.pre&&ci.post)full++; if(ci.pre?.status==="late"||ci.post?.status==="late")late++; } });
