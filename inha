    const enrolled = mk.some(id=>meetings[id].checkins?.[ME.id]) || seatK;
    if(enrolled){ const rate=mk.length?Math.round(full/mk.length*100):0; totMeet+=mk.length; totFull+=full;
      courseRows.push({code,name:c.name||code,total:mk.length,attended,full,late,rate,
        seat:seatK?`${seatK.split("-")[0]*1+1}-${colL(seatColIdx(c,seatK))}`:"-", meetings, mk}); }
  }
  const overallRate=totMeet?Math.round(totFull/totMeet*100):0;
