async function paintCell(code,r,c){ const s=allCourses[code]; const cells={...((s.config?.cells)||{})}; const k=`${r}-${c}`;
  if(TOOL==="seat")delete cells[k]; else if(TOOL==="erase")cells[k]="empty"; else cells[k]=TOOL;
  await cSet(code,{config:{...(s.config||{rows:5,cols:8}),cells}}); if(TOOL!=="seat"&&s.seats?.[k]) await set(ref(db,`courses/${code}/seats/${k}`),null); }
async function resize(code,rows,cols){ const s=allCourses[code]; const R=Math.max(1,Math.min(30,rows)),C=Math.max(1,Math.min(26,cols));
  const o=(s.config?.cells)||{},cells={}; for(const k of Object.keys(o)){const[r,c]=k.split("-").map(Number); if(r<R&&c<C)cells[k]=o[k];} await cSet(code,{config:{...(s.config||{}),rows:R,cols:C,cells}}); toast(bi("크기 적용","已应用尺寸"),"ok"); }
function parseRoster(text){ const out={}; text.split(/\r?\n/).forEach(line=>{ line=line.trim(); if(!line)return;
  const parts=line.split(/[,\t]/).length>1?line.split(/[,\t]/):line.split(/\s+/); const id=(parts[0]||"").trim(); const name=(parts.slice(1).join(" ")||"").trim();
  if(id&&!/^(학번|학생|id|이름|姓名|学号)$/i.test(id)) out[id]=name||id; }); return out; }
async function importRoster(code){ const parsed=parseRoster($("rosterText").value); const cnt=Object.keys(parsed).length;
  if(!cnt){toast("형식 확인 没解析到","warn");return;} const s=allCourses[code]; await cSet(code,{roster:{...(s.roster||{}),...parsed}}); toast(`${cnt}명 등록`,"ok"); }
