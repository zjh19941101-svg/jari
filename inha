function genCode(code,startAt,secret,now){ now=now||Date.now(); if(!startAt)return "------";
  const win=Math.floor((now-startAt)/(CODE_PERIOD*1000)); let seed=0x811c9dc5; const s=code+"|"+(secret||"")+"|"+win;
  for(let i=0;i<s.length;i++){seed^=s.charCodeAt(i);seed=(seed*16777619)>>>0;} return pad(seed%1000000,6); }
function codeAtWin(code,startAt,secret,off){ const win=Math.floor((Date.now()-startAt)/(CODE_PERIOD*1000))+off;
  let seed=0x811c9dc5; const s=code+"|"+(secret||"")+"|"+win; for(let i=0;i<s.length;i++){seed^=s.charCodeAt(i);seed=(seed*16777619)>>>0;} return pad(seed%1000000,6); }
function codeLeft(startAt){ if(!startAt)return 0; return CODE_PERIOD-(((Date.now()-startAt)/1000)%CODE_PERIOD); }
function randCode(){ const s="ABCDEFGHJKLMNPQRSTUVWXYZ23456789"; let o=""; for(let i=0;i<4;i++)o+=s[Math.floor(Math.random()*s.length)]; return o; }
function randSecret(){ let s=""; const ch="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"; for(let i=0;i<16;i++)s+=ch[Math.floor(Math.random()*ch.length)]; return s; }
function toast(m,k="info"){ const t=document.createElement("div"); t.className=`toast t-${k}`; t.textContent=m; document.body.appendChild(t); setTimeout(()=>t.remove(),2500); }
function fmtTime(ts){ if(!ts)return ""; const d=new Date(ts); const p=n=>String(n).padStart(2,"0");
  return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())} ${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`; }

