    <div id="scanMsg" class="tip" style="text-align:center;margin-top:10px">${bi('카메라 권한을 허용하세요','请允许摄像头权限')}</div>
    <button class="no" id="scanClose" style="width:100%;margin-top:12px">${t('close')}</button></div></div>`;
  $("scanClose").onclick=closeScanner; $("sov").onclick=e=>{if(e.target.id==="sov")closeScanner();};
  // 动态加载 html5-qrcode
  const startScan=()=>{
    try{
      _scanner=new Html5Qrcode("qrReader");
      _scanner.start({facingMode:"environment"},{fps:10,qrbox:{width:220,height:220}},
        txt=>{ // 扫到二维码:提取课程码
          let code=null; const m=String(txt).match(/c=([A-Z0-9]{4,6})/i); if(m)code=m[1].toUpperCase();
          else if(/^[A-Z0-9]{4,6}$/i.test(txt.trim()))code=txt.trim().toUpperCase();
          if(code){ closeScanner(); location.hash=`c=${code}`; subscribeCourse(code); VIEW="checkin"; toast(bi("입장 완료","已进入"),"ok"); render(); }
        },()=>{});
    }catch(e){ const sm=$("scanMsg"); if(sm)sm.textContent=bi("카메라를 열 수 없습니다","无法打开摄像头"); }
  };
  if(window.Html5Qrcode){ startScan(); }
  else { const sc=document.createElement("script"); sc.src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"; sc.onload=startScan;
    sc.onerror=()=>{ const sm=$("scanMsg"); if(sm)sm.textContent=bi("스캐너 로드 실패, 코드를 직접 입력하세요","扫描器加载失败,请手动输码"); }; document.head.appendChild(sc); }
}
