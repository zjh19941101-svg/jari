function seatMapHtmlFor(s,edit){ const cf=s.config,seats=s.seats||{}; let rows="";
  for(let r=0;r<cf.rows;r++){let cells="";
    for(let c=0;c<cf.cols;c++){const k=`${r}-${c}`,t=(cf.cells||{})[k]||"seat",occ=seats[k]; let cls="cell ",html="";
      if(t==="empty"){cls+="empty editable";html='<span class="c">·</span>';}
      else if(t==="stage"){cls+="estage";html='<span class="ico">🎤</span>';}
      else if(t==="door"){cls+="edoor";html='<span class="ico">🚪</span>';}
      else if(t==="window"){cls+="ewindow";html='<span class="ico">🪟</span>';}
      else if(occ){cls+="taken";html=`<span class="n">${occ.name.slice(0,2)}</span>`;}
      else{cls+="free";let i=0;for(let cc=0;cc<c;cc++)if(((cf.cells||{})[`${r}-${cc}`]||"seat")==="seat")i++;html=`<span class="c">${colL(i)}</span>`;}
      cells+=`<button class="cell ${cls}" data-r="${r}" data-c="${c}" data-edit="1">${html}</button>`;}
    rows+=`<div class="grow"><span class="rownum">${r+1}</span>${cells}</div>`;}
  return `<div class="stage"><div class="board">STAGE 讲台</div><div class="grid">${rows}</div></div>`;
}

function render(){
  // 独立投屏页:只显示干净大码,完全无管理界面
  if(IS_SCREEN){ renderScreen(); return; }
  if(!LANG){ buildDrawer(); $("app").innerHTML=""; langPicker(); return; }
  const ae=document.activeElement; if(ae&&(ae.tagName==='INPUT'||ae.tagName==='TEXTAREA')){ setTimeout(render,1200); return; }
  buildDrawer(); $("whoTop").textContent=isAdmin?(ADMIN?ADMIN.name:""):(ME?ME.name:"");
  if(isAdmin){
    if(!adminAuthed){ adminLogin(); $("bar").innerHTML=""; return; }
    try{ $("app").innerHTML=ADMIN_VIEW==="overview"?adminOverview():ADMIN_CUR?adminCourse(ADMIN_CUR):adminManage(); }
    catch(e){ console.error(e); $("app").innerHTML=`<div class="card"><h3>오류 出错</h3><p class="lead">데이터 문제일 수 있어요. 数据可能有问题。</p><button class="btn ghost" id="bk">목록 返回列表</button></div>`; const b=$("bk"); if(b)b.onclick=()=>{ADMIN_CUR=null;ADMIN_VIEW="list";render();}; }
    $("bar").innerHTML=""; bindAll(); return; }
  if(!ME){ studentLogin(); bindAll(); return; }
  if(VIEW==="me"){ $("app").innerHTML=`<div id="mehold"><p style="text-align:center;color:#9aa3ba;padding:40px">${bi('불러오는 중…','加载中…')}</p></div>`; bindAll(); meView().then(h=>{const x=$("mehold");if(x){x.innerHTML=h; bindAll();}}); return; }
  if((VIEW==="checkin"||VIEW==="seat")&&!COURSE_CODE){ VIEW="home"; }
  let body=VIEW==="home"?homeView():VIEW==="checkin"?checkinView():VIEW==="seat"?seatView():homeView();
  $("app").innerHTML=body+`<div class="foot">실시간 동기화 · ${COURSE_CODE?'코드 '+COURSE_CODE:'코드 없음'}</div>`;
  renderSeatBar(); bindAll();
}
// 独立投屏页
let _screenSub=false;
function renderScreen(){
  document.querySelector(".topbar").style.display="none"; $("bar").innerHTML="";
  if(!_screenSub){ _screenSub=true;
    if(SCREEN_FIXED){ onValue(ref(db,`courses`),s=>{ allCourses=s.val()||{}; paintScreen(); }); }
    else { const code=SCREEN[1].toUpperCase(); onValue(ref(db,`courses/${code}`),s=>{ allCourses[code]=s.exists()?s.val():null; paintScreen(); }); }
  }
  paintScreen();
  if(!window._screenTick){ window._screenTick=setInterval(paintScreen,250); }
}
// 找当前正在签到的课和段(固定投屏用)
function findLiveScreen(){
  for(const code of Object.keys(allCourses)){ const c=allCourses[code]; if(!c?.meetings)continue;
    const m=activeMeeting(c); if(!m)continue; const mm=c.meetings[m.id];
    if(mm.preOpen) return {code,ph:"pre",c,m,mm};
    if(mm.postOpen) return {code,ph:"post",c,m,mm};
  }
  return null;
}
function paintScreen(){
  const host=$("app"); if(!host)return;
  if(!document.getElementById("scrnWrap")){
    host.innerHTML=`<div id="scrnWrap" style="position:fixed;inset:0;background:linear-gradient(160deg,#1d4ed8,#2563eb 55%,#0ea5e9);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px">
      <div id="scrnName" style="font-size:clamp(20px,3.2vw,34px);font-weight:800"></div>
      <div id="scrnPhase" style="font-size:clamp(14px,2vw,22px);opacity:.85;margin-top:4px"></div>
      <div style="font-size:clamp(13px,1.6vw,18px);opacity:.7;margin:30px 0 4px;letter-spacing:3px">${bi('출석 코드','签到验证码')}</div>
      <div id="scrnCode" style="font-size:clamp(70px,20vw,210px);font-weight:800;letter-spacing:clamp(8px,3vw,30px);font-variant-numeric:tabular-nums;line-height:1.02;text-shadow:0 8px 36px rgba(0,0,0,.28)">------</div>
      <div style="display:flex;align-items:center;gap:14px;margin-top:22px">
        <div style="width:min(60vw,460px);height:12px;background:rgba(255,255,255,.25);border-radius:12px;overflow:hidden"><div id="scrnRing" style="height:100%;background:#fff;border-radius:12px;transition:width .25s linear;width:0%"></div></div>
        <div id="scrnSec" style="font-size:clamp(20px,2.4vw,30px);font-weight:800;min-width:2.4em;text-align:left">--</div></div>
      <div style="font-size:clamp(13px,1.6vw,18px);opacity:.8;margin-top:18px">${bi('15초마다 자동 변경','每15秒自动变化')}</div>
      <div id="scrnFoot" style="font-size:clamp(12px,1.4vw,15px);opacity:.65;margin-top:8px"></div></div>`;
  }
  let code,ph,c,m,mm;
  if(SCREEN_FIXED){ const live=findLiveScreen();
    if(!live){ $("scrnName").textContent=bi("자리 Jari 투사 화면","Jari 投屏"); $("scrnPhase").textContent=bi("진행 중인 출석이 없습니다","当前没有进行中的签到");
      $("scrnCode").textContent=bi("대기중","等待开始"); $("scrnRing").style.width="0%"; $("scrnSec").textContent="--"; $("scrnFoot").textContent=bi("휴대폰에서 출석을 시작하면 자동 표시","手机上开始签到后自动显示"); return; }
    ({code,ph,c,m,mm}=live);
  } else { code=SCREEN[1].toUpperCase(); ph=SCREEN[2].toLowerCase(); c=allCourses[code]; if(!c){ $("scrnCode").textContent=bi("강의 없음","无此课程"); return; } m=activeMeeting(c); mm=m&&c.meetings[m.id]; }
  const at=mm?(ph==="pre"?mm.preAt:mm.postAt):0; const sec=mm?(ph==="pre"?mm.preSec:mm.postSec):""; const open=mm&&(ph==="pre"?mm.preOpen:mm.postOpen);
  $("scrnName").textContent=c.name||code;
  $("scrnPhase").textContent=(ph==="pre"?bi("수업 전 출석","课前签到"):bi("수업 후 출석","课后签到"))+(m?.title?(" · "+m.title):"");
  $("scrnFoot").textContent=bi("강의 코드","课程码")+": "+code;
  if(!open||!at){ $("scrnCode").textContent=bi("대기중","等待开始"); $("scrnRing").style.width="0%"; $("scrnSec").textContent="--"; return; }
  $("scrnCode").textContent=genCode(code,at,sec);
  const left=codeLeft(at); $("scrnRing").style.width=(left/CODE_PERIOD*100)+"%"; $("scrnSec").textContent=Math.ceil(left)+"s";
}
function renderSeatBar(){
  if(VIEW!=="seat"||!COURSE||!seatOpenNow(COURSE)){ $("bar").innerHTML=""; return; }
  const seats=COURSE.seats||{}; const myKey=Object.keys(seats).find(k=>seats[k]?.id===ME.id);
  if(myKey){const[r,c]=myKey.split("-").map(Number); $("bar").innerHTML=`<div class="confirmbar"><div class="info">예매 완료 🎉<small>${seatName(r,c)}</small></div><button class="cancelbtn" id="cs">취소 取消</button></div>`; $("cs").onclick=cancelMySeat;}
  else if(HOLD){const[r,c]=HOLD.split("-").map(Number); $("bar").innerHTML=`<div class="confirmbar"><div class="info">선택한 좌석 已选<small>${seatName(r,c)}</small></div><button class="confirmbtn" id="gc">확정 确定 →</button></div>`; $("gc").onclick=askConfirm;}
  else $("bar").innerHTML=`<div class="confirmbar"><div class="info" style="color:#697089;font-weight:600">좌석을 선택하세요 请点座位</div><button class="confirmbtn" disabled>확정</button></div>`;
}
function bindAll(){
  $("menuBtn").onclick=()=>openDrawer(true); $("drawerBg").onclick=()=>openDrawer(false);
  document.querySelectorAll(".tile").forEach(b=>b.onclick=()=>drawerNav(b.dataset.go));
  $("enter")&&($("enter").onclick=()=>{const id=$("sid").value.trim(),name=$("sname").value.trim();if(!id||!name){toast("학번·이름 입력","warn");return;}ME={id,name};saveMe(id,name);VIEW="home";render();});
  document.querySelectorAll(".segbtn").forEach(b=>b.onclick=()=>{CHECKPHASE=b.dataset.phase;render();});
  $("doCheck")&&($("doCheck").onclick=doCheckin); $("cin")&&($("cin").onkeydown=e=>{if(e.key==="Enter")doCheckin();});
  $("sitBack")&&($("sitBack").onclick=()=>{const pf=prefSeat(COURSE_CODE);if(pf){HOLD=pf;render();}});
  document.querySelectorAll("[data-enter]").forEach(b=>b.onclick=()=>{ const code=b.dataset.enter; location.hash=`c=${code}`; subscribeCourse(code); VIEW="checkin"; render(); });
  document.querySelectorAll("[data-forget]").forEach(b=>b.onclick=()=>{ forgetCourse(b.dataset.forget); render(); });
  $("meJoin")&&($("meJoin").onclick=()=>joinPrompt());
  document.querySelectorAll(".cell").forEach(b=>b.onclick=()=>{const r=+b.dataset.r,c=+b.dataset.c; if(isAdmin)paintCell(ADMIN_CUR,r,c); else holdSeat(r,c);});
  $("newC")&&($("newC").onclick=()=>createCourse($("nName").value.trim(),+$("nLate").value||15));
  document.querySelectorAll("[data-open]").forEach(b=>b.onclick=()=>{ADMIN_CUR=b.dataset.open;ADMIN_VIEW="list";render();});
  document.querySelectorAll("[data-del]").forEach(b=>b.onclick=()=>deleteCourse(b.dataset.del));
  $("backList")&&($("backList").onclick=()=>{ADMIN_CUR=null;render();});
  $("startMeet")&&($("startMeet").onclick=()=>startMeeting(ADMIN_CUR));
  $("openFixed")&&($("openFixed").onclick=()=>{ window.open(location.origin+location.pathname+"#screen","_blank","noopener"); });
  document.querySelectorAll("[data-delm]").forEach(b=>b.onclick=()=>delMeeting(ADMIN_CUR,b.dataset.delm));
  document.querySelectorAll("[data-endm]").forEach(b=>b.onclick=()=>endMeeting(ADMIN_CUR,b.dataset.endm));
  document.querySelectorAll("[data-makeup]").forEach(b=>b.onclick=()=>{ const [code,mid]=b.dataset.makeup.split("|"); requestMakeup(code,mid); });
  document.querySelectorAll("[data-mkok]").forEach(b=>b.onclick=()=>approveMakeup(ADMIN_CUR,b.dataset.mkok,true));
  document.querySelectorAll("[data-mkno]").forEach(b=>b.onclick=()=>approveMakeup(ADMIN_CUR,b.dataset.mkno,false));
  document.querySelectorAll("[data-exparch]").forEach(b=>b.onclick=()=>exportMeetingCSV(ADMIN_CUR,b.dataset.exparch));
  document.querySelectorAll("[data-delarch]").forEach(b=>b.onclick=()=>delMeeting(ADMIN_CUR,b.dataset.delarch));
  const cur=ADMIN_CUR&&allCourses[ADMIN_CUR]; const mkNow=cur&&cur.meetings?Object.keys(cur.meetings).sort((a,b)=>(cur.meetings[b].at||0)-(cur.meetings[a].at||0))[0]:null;
  document.querySelectorAll("[data-startph]").forEach(b=>b.onclick=()=>startPhase(ADMIN_CUR,mkNow,b.dataset.startph));
  document.querySelectorAll("[data-stopph]").forEach(b=>b.onclick=()=>stopPhase(ADMIN_CUR,mkNow,b.dataset.stopph));
  document.querySelectorAll("[data-project]").forEach(b=>b.onclick=()=>{ const [cc,mid,ph]=b.dataset.project.split("|"); openProjection(cc,mid,ph); });
  $("manPre")&&($("manPre").onclick=()=>manualCheckin(ADMIN_CUR,mkNow,"pre"));
  $("manPost")&&($("manPost").onclick=()=>manualCheckin(ADMIN_CUR,mkNow,"post"));
  $("expM")&&($("expM").onclick=()=>exportMeetingCSV(ADMIN_CUR,mkNow));
  $("expCourse")&&($("expCourse").onclick=()=>exportCourseCSV(ADMIN_CUR));
  $("impR")&&($("impR").onclick=()=>importRoster(ADMIN_CUR));
  $("clrR")&&($("clrR").onclick=()=>clearRoster(ADMIN_CUR));
  $("rosterFile")&&($("rosterFile").onchange=e=>{const f=e.target.files[0];if(!f)return;const rd=new FileReader();rd.onload=()=>{if($("rosterText"))$("rosterText").value=rd.result;toast("파일 로드됨 已读入","info");};rd.readAsText(f,"utf-8");});
  $("toggleSeat")&&($("toggleSeat").onclick=()=>toggleSeatOpen(ADMIN_CUR));
  $("setWin")&&($("setWin").onclick=()=>setSeatWindow(ADMIN_CUR,$("sFrom").value,$("sTo").value));
  $("doResize")&&($("doResize").onclick=()=>resize(ADMIN_CUR,+$("rRows").value,+$("rCols").value));
  $("resetSeat")&&($("resetSeat").onclick=()=>resetSeats(ADMIN_CUR));
  document.querySelectorAll(".tool").forEach(b=>b.onclick=()=>{TOOL=b.dataset.tool;render();});
}
render();
</script>
