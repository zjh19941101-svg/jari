function seatColIdx(c,k){ const[r,cc]=k.split("-").map(Number); const cells=(c.config?.cells)||{}; let i=0; for(let x=0;x<cc;x++) if((cells[`${r}-${x}`]||"seat")==="seat")i++; return i; }
