    <div style="display:flex;align-items:center;gap:14px;margin:24px 0 10px"><div style="width:min(64vw,460px);height:11px;background:rgba(255,255,255,.25);border-radius:11px;overflow:hidden"><div id="projRing" style="height:100%;background:#fff;border-radius:11px;transition:width .25s linear;width:0%"></div></div>
