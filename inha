function closeProjection(){ if(_projTimer){clearInterval(_projTimer);_projTimer=null;} const o=$("projOv"); if(o)o.remove(); }

function activeMeeting(c){ if(!c?.meetings)return null; const keys=Object.keys(c.meetings).sort((a,b)=>(c.meetings[b].at||0)-(c.meetings[a].at||0));
  for(const k of keys){ const m=c.meetings[k]; if(m.preOpen||m.postOpen) return {id:k,...m}; } return keys[0]?{id:keys[0],...c.meetings[keys[0]]}:null; }
function seatOpenNow(c){ if(!c)return false; if(c.seatOpen===true) return true; if(c.seatFrom&&c.seatTo){ const n=Date.now(); return n>=c.seatFrom&&n<=c.seatTo; } return false; }

function rememberCourse(code,name){ try{ const j=JSON.parse(localStorage.getItem("my_courses")||"{}"); j[code]=name||j[code]||code; localStorage.setItem("my_courses",JSON.stringify(j)); }catch{} }
function myCourses(){ try{ return JSON.parse(localStorage.getItem("my_courses")||"{}"); }catch{ return {}; } }
function forgetCourse(code){ try{ const j=myCourses(); delete j[code]; localStorage.setItem("my_courses",JSON.stringify(j)); }catch{} }
function subscribeCourse(code){ COURSE_CODE=code; onValue(ref(db,`courses/${code}`),s=>{ const prev=COURSE; COURSE=s.exists()?s.val():null; if(COURSE)rememberCourse(code,COURSE.name); notifyChanges(prev,COURSE); render(); }); }
if(COURSE_CODE&&!isAdmin) subscribeCourse(COURSE_CODE);
if(isAdmin) onValue(ref(db,`courses`),s=>{ allCourses=s.val()||{}; render(); });

let _shown={};
function notifyChanges(prev,cur){ if(!cur||isAdmin||!ME)return;
  const m=activeMeeting(cur), pm=prev?activeMeeting(prev):null;
  if(m){ for(const ph of ["pre","post"]){ const opened=m[ph+"Open"]&&!(pm&&pm.id===m.id&&pm[ph+"Open"]);
    const signed=cur.meetings?.[m.id]?.checkins?.[ME.id]?.[ph];
    const tag=cur.code+"|"+m.id+"|"+ph+"|"+(ph==="pre"?m.preAt:m.postAt);
    if(opened&&!signed&&!_shown[tag]){ _shown[tag]=1; toast((ph==="pre"?"수업 전":"수업 후")+" 출석 시작! 签到开始","ok"); if(VIEW!=="checkin")CHECKPHASE=ph; } } }
  if(seatOpenNow(cur)&&!(prev&&seatOpenNow(prev))&&!_shown["seat|"+cur.code]){ _shown["seat|"+cur.code]=1; toast("좌석 선택 열림! 选座已开放","ok"); }
}

